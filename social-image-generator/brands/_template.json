{
  "$schema": "../brand-schema.json",
  "_comment": "BRAND CONFIGURATION TEMPLATE - Copy this file to create a new client brand configuration",
  "metadata": {
    "clientId": "client-slug",
    "name": "Client Name",
    "description": "Brief description of brand voice and aesthetic",
    "version": "1.0.0",
    "lastUpdated": "2025-11-25",
    "maintainer": "Your Name"
  },
  "colors": {
    "primary": {
      "main": "#000000",
      "light": "#333333",
      "dark": "#000000",
      "contrast": "#FFFFFF"
    },
    "secondary": {
      "main": "#666666",
      "light": "#888888",
      "dark": "#444444",
      "contrast": "#FFFFFF"
    },
    "accent": {
      "main": "#FF6B35",
      "light": "#FF8C5E",
      "dark": "#CC5529"
    },
    "neutral": {
      "white": "#FFFFFF",
      "offWhite": "#F8F9FA",
      "lightGray": "#E9ECEF",
      "gray": "#6C757D",
      "darkGray": "#343A40",
      "black": "#1A1A1A"
    },
    "text": {
      "primary": "#1A1A1A",
      "secondary": "#6C757D",
      "inverse": "#FFFFFF",
      "link": "#0066CC"
    },
    "background": {
      "light": "#FFFFFF",
      "medium": "#F8F9FA",
      "dark": "#1A1A1A",
      "inverse": "#1A1A1A"
    },
    "semantic": {
      "success": "#28A745",
      "warning": "#FFC107",
      "error": "#DC3545",
      "info": "#17A2B8"
    },
    "gradients": [
      {
        "name": "primary-gradient",
        "type": "linear",
        "angle": 135,
        "stops": [
          { "color": "#000000", "position": 0 },
          { "color": "#333333", "position": 100 }
        ],
        "css": "linear-gradient(135deg, #000000 0%, #333333 100%)"
      }
    ]
  },
  "typography": {
    "families": {
      "primary": {
        "name": "Inter",
        "fallback": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif",
        "weights": [400, 500, 600, 700]
      },
      "heading": {
        "name": "Inter",
        "fallback": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif",
        "weights": [700, 800, 900]
      }
    },
    "scale": {
      "base": 16,
      "ratio": 1.25
    },
    "hierarchy": {
      "h1": {
        "size": 64,
        "weight": 800,
        "lineHeight": 1.1,
        "letterSpacing": "-0.02em"
      },
      "h2": {
        "size": 48,
        "weight": 700,
        "lineHeight": 1.2,
        "letterSpacing": "-0.01em"
      },
      "h3": {
        "size": 36,
        "weight": 700,
        "lineHeight": 1.3,
        "letterSpacing": "0"
      },
      "body": {
        "size": 18,
        "weight": 400,
        "lineHeight": 1.6,
        "letterSpacing": "0"
      },
      "quote": {
        "size": 48,
        "weight": 700,
        "lineHeight": 1.3,
        "letterSpacing": "-0.01em"
      },
      "caption": {
        "size": 24,
        "weight": 500,
        "lineHeight": 1.4,
        "letterSpacing": "0.05em",
        "textTransform": "uppercase"
      }
    }
  },
  "logos": {
    "primary": {
      "path": "assets/CLIENT-SLUG/logos/logo-primary.png",
      "format": "png",
      "variants": ["light", "dark"],
      "minWidth": 100,
      "maxWidth": 200,
      "aspectRatio": "16:9",
      "preferredPlacement": ["bottom-center"]
    },
    "inverse": {
      "path": "assets/CLIENT-SLUG/logos/logo-inverse.png",
      "format": "png",
      "usage": "Dark backgrounds"
    },
    "icon": {
      "path": "assets/CLIENT-SLUG/logos/icon.png",
      "format": "png",
      "size": 512
    }
  },
  "layout": {
    "safeZones": {
      "instagram": {
        "feed": {
          "top": 80,
          "bottom": 80,
          "left": 80,
          "right": 80
        },
        "story": {
          "top": 250,
          "bottom": 250,
          "left": 60,
          "right": 60
        }
      },
      "facebook": {
        "post": {
          "top": 60,
          "bottom": 60,
          "left": 60,
          "right": 60
        }
      },
      "twitter": {
        "post": {
          "top": 60,
          "bottom": 60,
          "left": 60,
          "right": 60
        }
      }
    },
    "grid": {
      "columns": 12,
      "gutter": 20,
      "margin": 40
    },
    "spacing": {
      "xs": 8,
      "sm": 16,
      "md": 24,
      "lg": 40,
      "xl": 64,
      "xxl": 96
    }
  },
  "platforms": {
    "instagram": {
      "feed": {
        "dimensions": {
          "width": 1080,
          "height": 1080
        },
        "format": "jpg",
        "quality": 90,
        "maxFileSize": "8MB"
      },
      "story": {
        "dimensions": {
          "width": 1080,
          "height": 1920
        },
        "format": "jpg",
        "quality": 90,
        "maxFileSize": "8MB"
      },
      "carousel": {
        "dimensions": {
          "width": 1080,
          "height": 1080
        },
        "format": "jpg",
        "quality": 90,
        "maxFileSize": "8MB"
      }
    },
    "facebook": {
      "post": {
        "dimensions": {
          "width": 1200,
          "height": 630
        },
        "format": "jpg",
        "quality": 90,
        "maxFileSize": "8MB"
      },
      "story": {
        "dimensions": {
          "width": 1080,
          "height": 1920
        },
        "format": "jpg",
        "quality": 90,
        "maxFileSize": "4MB"
      }
    },
    "twitter": {
      "post": {
        "dimensions": {
          "width": 1200,
          "height": 675
        },
        "format": "jpg",
        "quality": 90,
        "maxFileSize": "5MB"
      }
    },
    "linkedin": {
      "post": {
        "dimensions": {
          "width": 1200,
          "height": 627
        },
        "format": "jpg",
        "quality": 90,
        "maxFileSize": "5MB"
      }
    }
  },
  "imagery": {
    "style": "clean, modern, professional",
    "filters": {
      "brightness": 1.0,
      "contrast": 1.0,
      "saturation": 1.0
    },
    "overlays": {
      "default": "gradient",
      "opacity": 0.7
    }
  },
  "templates": {
    "enabled": [
      "quote-gradient",
      "quote-minimal"
    ],
    "defaults": {
      "quote": "quote-gradient"
    }
  },
  "validation": {
    "contrastMinimum": "AA",
    "accessibilityLevel": "WCAG2.0-AA",
    "maxTextLength": 280
  },
  "_instructions": {
    "1": "Copy this file to create a new brand configuration",
    "2": "Replace CLIENT-SLUG with your client's slug (lowercase, hyphens only)",
    "3": "Update all colors to match brand guidelines",
    "4": "Configure typography to match brand fonts",
    "5": "Create logo assets in assets/CLIENT-SLUG/logos/",
    "6": "Run validation: node cli.js validate --client CLIENT-SLUG",
    "7": "Test generation: node cli.js generate --client CLIENT-SLUG --template quote-gradient --content 'Test message'"
  }
}
